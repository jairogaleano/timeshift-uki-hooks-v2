#
# Contexto: Despues de restaurar un snapshot de Btrfs, este script recupera los UKIs
# que estaban guardados en /etc/timeshift/uki-backup/ (incluidos en el snapshot) y los
# devuelve a la particion EFI (ESP) para que coincidan con el kernel/modulos restaurados.
#
# Seguridad: Los UKIs ya estaban verificados por Secure Boot antes de ser respaldados.
# Este script solo restaura archivos existentes y calcula checksums para verificar integridad.
#

set -euo pipefail

BACKUP_DIR="/etc/timeshift/uki-backup"
LOG_FILE="/var/log/timeshift.log"
MIN_ESP_SPACE_MB=50
# ----------------------

log() {
    local level="$1"
    shift
    local message="$*"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [UKI Restore Hook] [$level] $message"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [UKI Restore Hook] [$level] $message" >> "$LOG_FILE" 2>/dev/null || true
}

echo "=== [UKI Restore Hook] Iniciando restauracion ===" >> "$LOG_FILE" 2>/dev/null || true

WAS_RO=false
TARGET_MNT=""
IN_CHROOT=false

if systemd-detect-virt --chroot >/dev/null 2>&1; then
    IN_CHROOT=true
    log "INFO" "Entorno chroot detectado. Ajustando rutas de montaje."
fi

# 1. Resolver el punto de montaje de la particion de arranque
# Busca en orden: /boot, /efi, /boot/efi, luego deteccion dinamica por tipo vfat
resolve_esp_mount() {
    local dirs=("/boot" "/efi" "/boot/efi")
    for d in "${dirs[@]}"; do
        if [ -d "$d" ] && [ ! -L "$d" ] && mountpoint -q "$d" 2>/dev/null; then
            echo "$d"
            return 0
        fi
    done
    local esp
    esp=$(findmnt -no TARGET -t vfat 2>/dev/null | head -1)
    if [ -n "$esp" ] && [ -d "$esp" ]; then
        echo "$esp"
        return 0
    fi
    return 1
}

# 2. Asegurar el montaje de la particion de arranque
if ! TARGET_MNT=$(resolve_esp_mount); then
    for mnt in /boot /efi /boot/efi; do
        if [ -d "$mnt" ] && [ ! -L "$mnt" ]; then
            if ! mountpoint -q "$mnt" 2>/dev/null; then
                log "INFO" "Intentando montar $mnt..."
                if mount "$mnt" 2>/dev/null; then
                    TARGET_MNT="$mnt"
                    log "INFO" "$mnt montado exitosamente."
                    break
                fi
            fi
        fi
    done
fi

if [ -z "$TARGET_MNT" ]; then
    log "ERROR" "No se pudo detectar ni montar la particion EFI (ESP)"
    exit 1
fi

log "INFO" "ESP montada en: $TARGET_MNT"

# Comprobar si esta montado en modo solo lectura (ro)
if findmnt -O ro "$TARGET_MNT" >/dev/null 2>&1; then
    log "INFO" "$TARGET_MNT esta montado como SOLO LECTURA. Remontando en modo LECTURA-ESCRITURA..."
    if ! mount -o remount,rw "$TARGET_MNT" 2>/dev/null; then
        log "ERROR" "No se pudo remontar $TARGET_MNT como RW"
        exit 1
    fi
    WAS_RO=true
fi

# 3. Determinar la ruta de destino para UKIs
UKI_DIR="$TARGET_MNT/EFI/Linux"
if [ ! -d "$UKI_DIR" ]; then
    mkdir -p "$UKI_DIR"
    log "INFO" "Directorio $UKI_DIR creado en ESP."
fi

# 4. Verificar si existe el directorio de respaldo
if [ ! -d "$BACKUP_DIR" ]; then
    log "ERROR" "No se encontro el directorio de respaldo $BACKUP_DIR"
    if [ "$WAS_RO" = true ]; then
        mount -o remount,ro "$TARGET_MNT"
    fi
    exit 1
fi

shopt -s nullglob
backup_ukis=("$BACKUP_DIR"/*.efi)
shopt -u nullglob

if [ ${#backup_ukis[@]} -eq 0 ]; then
    log "ERROR" "No se encontraron archivos UKI (.efi) de respaldo en $BACKUP_DIR"
    if [ "$WAS_RO" = true ]; then
        mount -o remount,ro "$TARGET_MNT"
    fi
    exit 1
fi

# 5. Verificar espacio disponible en ESP
esp_avail_kb=$(df -P "$TARGET_MNT" 2>/dev/null | awk 'NR==2 {print $4}')
esp_avail_mb=$((esp_avail_kb / 1024)) 2>/dev/null || esp_avail_mb=0
if [ "$esp_avail_mb" -lt "$MIN_ESP_SPACE_MB" ] && [ "$esp_avail_mb" -gt 0 ]; then
    log "WARN" "Poco espacio disponible en ESP: ${esp_avail_mb}MB (minimo recomendado: ${MIN_ESP_SPACE_MB}MB)"
    log "WARN" "Continuando de todas formas..."
elif [ "$esp_avail_mb" -gt 0 ]; then
    log "INFO" "Espacio disponible en ESP: ${esp_avail_mb}MB"
fi

# 6. Limpiar archivos .sha256 huerfanos en respaldo
for sha_file in "$BACKUP_DIR"/*.sha256; do
    [ -f "$sha_file" ] || continue
    efi_file="${sha_file%.sha256}"
    if [ ! -f "$efi_file" ]; then
        rm -f "$sha_file"
        log "INFO" "Limpiado .sha256 huerfano: ${sha_file##*/}"
    fi
done

# 7. Restaurar UKIs con verificacion de integridad
log "INFO" "Verificando integridad de UKIs respaldados..."

restored_count=0
for uki_backup in "${backup_ukis[@]}"; do
    [ -f "$uki_backup" ] || continue

    basename="${uki_backup##*/}"
    sha_file="${uki_backup%.efi}.sha256"
    expected_sha=""

    if [ -f "$sha_file" ]; then
        expected_sha=$(<"$sha_file")
        actual_sha=$(sha256sum "$uki_backup" | awk '{print $1}')

        if [ "$expected_sha" != "$actual_sha" ]; then
            log "ERROR" "Checksum fallo para $basename. Esperado: $expected_sha, Actual: $actual_sha"
            if [ "$WAS_RO" = true ]; then
                mount -o remount,ro "$TARGET_MNT"
            fi
            exit 1
        fi
        log "INFO" "Checksum verificado para $basename"
    else
        log "WARN" "No se encontro archivo SHA256 para $basename, continuando sin verificacion"
    fi

    # Saltar si el archivo ya existe y es identico
    if [ -f "$UKI_DIR/$basename" ]; then
        current_sha=$(sha256sum "$UKI_DIR/$basename" | awk '{print $1}')
        if [ -n "$expected_sha" ] && [ "$current_sha" == "$expected_sha" ]; then
            log "INFO" "El archivo $basename ya existe y es identico en el destino. Saltando."
            continue
        fi
    fi

    # Copiar de forma atomica: escribir en temp, verificar, luego mover
    temp_file="$(mktemp "$UKI_DIR/.tmp_XXXXXXXX")"
    if cp --preserve=all "$uki_backup" "$temp_file"; then
        if mv "$temp_file" "$UKI_DIR/$basename"; then
            log "INFO" "Restaurado: $basename"
            ((restored_count++))
        else
            log "ERROR" "No se pudo completar la copia atomica de $basename"
            rm -f "$temp_file"
            if [ "$WAS_RO" = true ]; then
                mount -o remount,ro "$TARGET_MNT"
            fi
            exit 1
        fi
    else
        log "ERROR" "No se pudo copiar $basename"
        rm -f "$temp_file"
        if [ "$WAS_RO" = true ]; then
            mount -o remount,ro "$TARGET_MNT"
        fi
        exit 1
    fi
done

# 8. Devolver la particion a modo SOLO LECTURA si originalmente estaba asi
if [ "$WAS_RO" = true ] && [ -n "$TARGET_MNT" ]; then
    log "INFO" "Restaurando $TARGET_MNT a modo SOLO LECTURA..."
    mount -o remount,ro "$TARGET_MNT"
fi

# 9. Reportar resultado final
if [ "$restored_count" -gt 0 ]; then
    log "INFO" "EXITO: $restored_count UKIs restaurados correctamente"
    echo "=== [UKI Restore Hook] EXITO: $restored_count UKIs restaurados ===" >> "$LOG_FILE" 2>/dev/null || true
else
    log "INFO" "No se restauraron archivos (puede ser que el respaldo ya no contenga UKIs .efi)"
    echo "=== [UKI Restore Hook] Finalizado: Sin archivos restaurados ===" >> "$LOG_FILE" 2>/dev/null || true
fi

exit 0
