#
# Contexto: Timeshift crea snapshots de Btrfs que protegen /, pero no la particion EFI (ESP)
# donde residen los UKIs. Este hook respalda los UKIs actuales en /etc/timeshift/uki-backup/
# para que se incluyan en el snapshot de Btrfs y puedan restaurarse posteriormente.
#

set -euo pipefail

# --- CONFIGURACION ---
BACKUP_DIR="/etc/timeshift/uki-backup"
LOG_FILE="/var/log/timeshift.log"
# ----------------------

log() {
    local level="$1"
    shift
    local message="$*"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [UKI Backup Hook] [$level] $message"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [UKI Backup Hook] [$level] $message" >> "$LOG_FILE" 2>/dev/null || true
}

detect_uki_dir() {
    local dirs=("/boot/EFI/Linux" "/efi/EFI/Linux" "/boot/efi/EFI/Linux")
    for d in "${dirs[@]}"; do
        if [ -d "$d" ]; then
            echo "$d"
            return 0
        fi
    done
    local esp
    esp=$(findmnt -no TARGET -t vfat 2>/dev/null | while read -r mnt; do
        if [ -d "$mnt/EFI/Linux" ]; then echo "$mnt"; break; fi
    done)
    if [ -n "$esp" ]; then
        echo "$esp/EFI/Linux"
        return 0
    fi
    return 1
}

mkdir -p "$BACKUP_DIR"

UKI_DIR=$(detect_uki_dir) || true
if [ -z "$UKI_DIR" ]; then
    log "WARN" "No se pudo detectar el directorio de UKIs"
    exit 0
fi

log "INFO" "UKI directory detectado: $UKI_DIR"

shopt -s nullglob
uki_files=("$UKI_DIR"/*.efi)
shopt -u nullglob

if [ ${#uki_files[@]} -eq 0 ]; then
    log "WARN" "No se encontraron archivos UKI (.efi) en $UKI_DIR"
    exit 0
fi

log "INFO" "Iniciando analisis de UKIs en $UKI_DIR"

# Limpiar archivos .bak huerfanos en UKI_DIR (rotaciones viejas que no deberian estar)
shopt -s nullglob
for bak_file in "$UKI_DIR"/*.bak.*.efi "$UKI_DIR"/*.bak.efi; do
    [ -f "$bak_file" ] || continue
    rm -f "$bak_file"
    log "INFO" "Limpiado .bak huerfano en ESP: ${bak_file##*/}"
done
shopt -u nullglob

# Limpiar archivos .bak huerfanos en BACKUP_DIR
shopt -s nullglob
for bak_file in "$BACKUP_DIR"/*.bak.*.efi "$BACKUP_DIR"/*.bak.efi "$BACKUP_DIR"/*.bak.*.efi.sha256 "$BACKUP_DIR"/*.bak.efi.sha256; do
    [ -f "$bak_file" ] || continue
    rm -f "$bak_file"
    log "INFO" "Limpiado .bak huerfano en respaldo: ${bak_file##*/}"
done
shopt -u nullglob

needs_backup=false
for uki in "${uki_files[@]}"; do
    [ -f "$uki" ] || continue
    basename="${uki##*/}"

    # Omitir archivos .bak (rotaciones viejas)
    if [[ "$basename" == *".bak."* || "$basename" == *".bak.efi" ]]; then
        continue
    fi

    if [ -f "$BACKUP_DIR/$basename" ]; then
        current_sha=$(sha256sum "$uki" | awk '{print $1}')
        backup_sha=$(sha256sum "$BACKUP_DIR/$basename" | awk '{print $1}')

        if [ "$current_sha" == "$backup_sha" ]; then
            log "INFO" "$basename es identico al respaldo actual. No se requiere nuevo respaldo."
            continue
        fi
    fi
    needs_backup=true
done

if [ "$needs_backup" = false ]; then
    log "INFO" "Todos los UKIs estan actualizados en el respaldo. Saltando proceso de copia."
    exit 0
fi

log "INFO" "Iniciando respaldo de UKIs desde $UKI_DIR"

# Limpiar archivos .sha256 huerfanos (de UKIs que ya no existen)
for sha_file in "$BACKUP_DIR"/*.sha256; do
    [ -f "$sha_file" ] || continue
    efi_file="${sha_file%.sha256}"
    if [ ! -f "$efi_file" ]; then
        rm -f "$sha_file"
        log "INFO" "Limpiado .sha256 huerfano: ${sha_file##*/}"
    fi
done

cp_count=0
for uki in "${uki_files[@]}"; do
    [ -f "$uki" ] || continue

    basename="${uki##*/}"

    # Omitir archivos .bak (rotaciones viejas)
    if [[ "$basename" == *".bak."* || "$basename" == *".bak.efi" ]]; then
        continue
    fi

    current_sha=$(sha256sum "$uki" | awk '{print $1}')
    if [ -f "$BACKUP_DIR/$basename" ]; then
        backup_sha=$(sha256sum "$BACKUP_DIR/$basename" | awk '{print $1}')
        if [ "$current_sha" == "$backup_sha" ]; then
            continue
        fi
    fi

    if cp --preserve=all "$uki" "$BACKUP_DIR/$basename"; then
        echo "$current_sha" > "$BACKUP_DIR/$basename.sha256"
        log "INFO" "Respaldo exitoso: $basename"
        cp_count=$((cp_count + 1))
    else
        log "ERROR" "Fallo en copia de: $basename"
        exit 1
    fi
done

if [ "$cp_count" -gt 0 ]; then
    log "INFO" "Finalizado: $cp_count UKIs respaldados"
else
    log "INFO" "Finalizado: Sin cambios"
fi

exit 0
