#
# Contexto: Timeshift crea snapshots de Btrfs que protegen /, pero no la particion EFI (ESP)
# donde residen los UKIs. Este hook respalda los UKIs actuales en /etc/timeshift/uki-backup/
# para que se incluyan en el snapshot de Btrfs y puedan restaurarse posteriormente.
#

set -euo pipefail

# --- CONFIGURACION ---
UKI_DIR="/boot/EFI/Linux"
if [ ! -d "$UKI_DIR" ]; then
    UKI_DIR="/efi/EFI/Linux"
fi

BACKUP_DIR="/etc/timeshift/uki-backup"
LOG_FILE="/var/log/timeshift.log"
# ----------------------

log() {
    local level="$1"
    shift
    local message="$*"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [UKI Backup Hook] [$level] $message"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [UKI Backup Hook] [$level] $message" >> "$LOG_FILE" 2>/dev/null || true
}

mkdir -p "$BACKUP_DIR"

if [ -d "$UKI_DIR" ] && ls "$UKI_DIR"/*.efi >/dev/null 2>&1; then
    log "INFO" "Iniciando analisis de UKIs en $UKI_DIR"

    uki_files=("$UKI_DIR"/*.efi)
    needs_backup=false

    for uki in "${uki_files[@]}"; do
        [ -f "$uki" ] || continue
        basename="${uki##*/}"

        if [ -f "$BACKUP_DIR/$basename" ]; then
            current_sha=$(sha256sum "$uki" | awk '{print $1}')
            backup_sha=$(sha256sum "$BACKUP_DIR/$basename" | awk '{print $1}')

            if [ "$current_sha" == "$backup_sha" ]; then
                log "INFO" "$basename es identico al respaldo actual. No se requiere nuevo respaldo."
                continue
            fi
        fi
        needs_backup=true
    done
else
    log "WARN" "No se encontraron archivos UKI (.efi) en $UKI_DIR"
    exit 0
fi

if [ "$needs_backup" = false ]; then
    log "INFO" "Todos los UKIs estan actualizados en el respaldo. Saltando proceso de copia."
    echo "=== [UKI Backup Hook] Finalizado: Sin cambios detectados, respaldo omitido ===" >> "$LOG_FILE" 2>/dev/null || true
    exit 0
fi

log "INFO" "Iniciando respaldo de UKIs desde $UKI_DIR"

cp_count=0
for uki in "${uki_files[@]}"; do
    [ -f "$uki" ] || continue

    basename="${uki##*/}"

    current_sha=$(sha256sum "$uki" | awk '{print $1}')
    if [ -f "$BACKUP_DIR/$basename" ]; then
        backup_sha=$(sha256sum "$BACKUP_DIR/$basename" | awk '{print $1}')
        if [ "$current_sha" == "$backup_sha" ]; then
            continue
        fi
    fi

    if cp --preserve=all "$uki" "$BACKUP_DIR/$basename"; then
        echo "$current_sha" > "$BACKUP_DIR/$basename.sha256"
        log "INFO" "Respaldo exitoso: $basename"
        cp_count=$((cp_count + 1))
    else
        log "ERROR" "Fallo en copia de: $basename"
        exit 1
    fi
done

if [ "$cp_count" -gt 0 ]; then
    log "INFO" "Total de UKIs respaldados: $cp_count"
    echo "=== [UKI Backup Hook] Finalizado: $cp_count UKIs respaldados ===" >> "$LOG_FILE" 2>/dev/null || true
else
    log "INFO" "No se encontraron UKIs (archivos .efi) en $UKI_DIR"
    echo "=== [UKI Backup Hook] Finalizado: No se encontraron UKIs ===" >> "$LOG_FILE" 2>/dev/null || true
fi

exit 0
